# Mneme 环境变量配置
# 复制为 .env 并填入实际值：cp .env.example .env

# ============================================================================
# LLM API Keys（至少配置一个，或使用 provider = "mock" 跳过）
# ============================================================================

# Anthropic (默认 provider)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI / DeepSeek（使用 openai provider 时需要）
# OPENAI_API_KEY=sk-xxxxx

# ============================================================================
# LLM 配置覆盖（优先级高于 mneme.toml，通常不需要设置）
# ============================================================================

# LLM_PROVIDER=anthropic          # anthropic | openai | deepseek | ollama | mock
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# LLM_BASE_URL=                   # 自定义 API 端点（代理/中转）
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7
# LLM_CONTEXT_BUDGET=60000        # 上下文预算（字符数）
# LLM_TIMEOUT_SECS=30

# ============================================================================
# 自定义 API 端点（可选，用于代理或自部署）
# ============================================================================

# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ============================================================================
# OneBot QQ 机器人（可选，需 --features onebot 编译）
# ============================================================================

# ONEBOT_WS_URL=ws://localhost:8080
# ONEBOT_ACCESS_TOKEN=your-token-here

# ============================================================================
# Gateway 网关（可选，需 --features gateway 编译）
# ============================================================================

# GATEWAY_URL=http://127.0.0.1:3000

# ============================================================================
# 可观测性（可选）
# ============================================================================

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317   # OpenTelemetry（需 --features otlp）
# MNEME_METRICS_PORT=9090                              # Prometheus（需 --features prometheus）

# ============================================================================
# 调试（开发用）
# ============================================================================

# DEBUG_PAYLOAD=true               # 打印完整 LLM 请求/响应
# ANTHROPIC_LEGACY_SYSTEM=false    # 使用旧版 system prompt 格式
